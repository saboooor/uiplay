{
  "name": "uiplay",
  "description": "UI wrapper for uxplay",
  "version": "0.0.1",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LuminescentDev/uiplay.git"
  },
  "engines": {
    "node": ">=21.0.0"
  },
  "engines-annotation": "Mostly required by sharp which needs a Node-API v9 compatible runtime",
  "private": false,
  "type": "module",
  "scripts": {
    "build": "qwik build",
    "build.client": "vite build",
    "build.preview": "vite build --ssr src/entry.preview.tsx",
    "build.server": "vite build -c adapters/static/vite.config.ts",
    "build.tauri": "vite build -c adapters/static/vite.config.ts",
    "build.types": "tsc --incremental --noEmit",
    "deploy": "echo 'Run \"npm run qwik add\" to install a server adapter'",
    "dev": "vite --mode ssr",
    "dev.debug": "node --inspect-brk ./node_modules/vite/bin/vite.js --mode ssr --force",
    "fmt": "prettier --write .",
    "fmt.check": "prettier --check .",
    "lint": "eslint \"src/**/*.ts*\"",
    "preview": "qwik build preview && vite preview --open",
    "start": "vite --open --mode ssr",
    "qwik": "qwik",
    "tauri": "tauri"
  },
  "devDependencies": {
    "@anuragroy/tailwindcss-animate": "^1.0.6",
    "@eslint/js": "^10.0.1",
    "@luminescent/ui": "^7.0.0",
    "@luminescent/ui-qwik": "^7.0.0-3",
    "@qwik.dev/core": "2.0.0-beta.37",
    "@qwik.dev/router": "2.0.0-beta.37",
    "@tailwindcss/vite": "^4.3.0",
    "@tauri-apps/api": "2.11.0",
    "@tauri-apps/cli": "2.11.2",
    "@tauri-apps/plugin-fs": "^2.5.1",
    "@types/node": "25.9.3",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "eslint": "10.4.1",
    "eslint-plugin-qwik": "2.0.0-beta.37",
    "globals": "17.6.0",
    "lucide-icons-qwik": "^1.16.0-qwik-v2",
    "prettier": "3.8.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4.3.0",
    "ts-morph": "23",
    "typescript": "6.0.3",
    "typescript-eslint": "8.61.0",
    "undici": "^8.4.1",
    "vite": "7",
    "vite-tsconfig-paths": "^6.1.1"
  }
}
